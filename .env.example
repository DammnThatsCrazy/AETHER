# =============================================================================
# Aether Platform — Environment Variables
#
# Copy to .env and customize for your environment:
#   cp .env.example .env
#
# All variables have sensible defaults for local development.
# Variables marked [REQUIRED IN PRODUCTION] must be set for non-local envs.
# =============================================================================

# === General ===
AETHER_ENV=local                       # local | dev | staging | production
DEBUG=true

# === Database — PostgreSQL (asyncpg) ===
# DATABASE_URL is the primary connection string used by repositories.
# Individual TSDB_* vars are kept for backward compatibility with deployment scripts.
DATABASE_URL=                            # [REQUIRED IN PRODUCTION] e.g. postgresql://aether:pass@db:5432/aether
TSDB_HOST=localhost
TSDB_PORT=5432
TSDB_DATABASE=aether
TSDB_USER=aether
TSDB_PASSWORD=                          # [REQUIRED IN PRODUCTION]
TSDB_POOL_MIN=5
TSDB_POOL_MAX=20

# === Database — Amazon Neptune (Graph) ===
NEPTUNE_ENDPOINT=localhost
NEPTUNE_PORT=8182
AWS_REGION=us-east-1

# === Cache — Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# === Database — DynamoDB ===
DYNAMODB_ENDPOINT=                      # Leave empty for AWS; set for local DynamoDB
DYNAMODB_TABLE_PREFIX=aether_

# === Database — OpenSearch ===
OPENSEARCH_ENDPOINT=localhost
OPENSEARCH_PORT=9200

# === Event Bus — Kafka / SNS+SQS ===
EVENT_BROKER=kafka                      # kafka | sns_sqs
KAFKA_BOOTSTRAP_SERVERS=localhost:9092   # [REQUIRED IN PRODUCTION] Used by aiokafka producer/consumer
KAFKA_BROKERS=localhost:9092            # Legacy alias
KAFKA_CONSUMER_GROUP=aether-backend
SNS_TOPIC_ARN=
SQS_QUEUE_URL=

# === API Configuration ===
CORS_ORIGINS=http://localhost:3000,https://app.aether.io
MAX_REQUEST_BODY_MB=10

# === Self-Serve Plans & Rate Limiting ===
# Active pricing strategy. Selects which subscription/overage rate sheet
# is used by the OverageCalculator at billing time. Validated A/B/C at
# startup.  A = Market Entry, B = Ideal/Fair, C = Premium.
PRICING_OPTION=B
# Days to retain Redis quota counters (rl:quota:* and rl:overage:*).
QUOTA_REDIS_TTL_DAYS=35
# Interval (seconds) for the background quota -> tenant_usage flusher.
QUOTA_FLUSH_INTERVAL_S=60

# === Authentication ===
JWT_SECRET=change-me-in-production      # [REQUIRED IN PRODUCTION]
JWT_EXPIRY_MINUTES=60

# === Intelligence Graph Feature Flags ===
IG_AGENT_LAYER=false
IG_COMMERCE_LAYER=false
IG_X402_LAYER=false
IG_ONCHAIN_LAYER=false
IG_TRUST_SCORING=false
IG_BYTECODE_RISK=false
IG_RPC_GATEWAY=false

# === QuickNode (Blockchain RPC) ===
QUICKNODE_API_KEY=
QUICKNODE_ENDPOINT=
QUICKNODE_X402_ENABLED=false
QUICKNODE_MAX_RPS=100

# === Provider Gateway ===
PROVIDER_GATEWAY_ENABLED=false
BYOK_ENCRYPTION_KEY=                    # [REQUIRED IN PRODUCTION] Fernet key for BYOK vault (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PROVIDER_GATEWAY_ENCRYPTION_KEY=        # Legacy alias for BYOK_ENCRYPTION_KEY
ALCHEMY_API_KEY=
ALCHEMY_ENDPOINT=
INFURA_API_KEY=
INFURA_PROJECT_ID=
ETHERSCAN_API_KEY=
MORALIS_API_KEY=
PROVIDER_MAX_RETRIES=2
PROVIDER_CB_THRESHOLD=5
PROVIDER_CB_TIMEOUT_S=30
PROVIDER_METER_FLUSH_S=60

# === Model Extraction Defense ===
ENABLE_EXTRACTION_DEFENSE=false
ENABLE_OUTPUT_NOISE=true
ENABLE_WATERMARK=true
ENABLE_QUERY_ANALYSIS=true
WATERMARK_SECRET_KEY=aether-wm-default-change-me   # [REQUIRED IN PRODUCTION]
CANARY_SECRET_SEED=aether-canary-seed-change-me     # [REQUIRED IN PRODUCTION]
EXTRACTION_KEY_RPM=60
EXTRACTION_KEY_RPH=1000
EXTRACTION_KEY_RPD=10000
EXTRACTION_IP_RPM=120
EXTRACTION_IP_RPH=3000
EXTRACTION_IP_RPD=30000
EXTRACTION_NOISE_STD=0.02
EXTRACTION_OUTPUT_PRECISION=2

# === Extraction Defense Mesh (distributed multi-identity layer) ===
ENABLE_EXTRACTION_MESH=false
EXTRACTION_BUDGET_ENABLED=true
EXTRACTION_EXPECTATION_ENABLED=true
EXTRACTION_POLICY_ENABLED=true
EXTRACTION_ATTRIBUTION_ENABLED=true
EXTRACTION_CANARY_SEED=aether-mesh-canary-seed       # [REQUIRED IN PRODUCTION when mesh enabled]
EXTRACTION_TELEMETRY_ENABLED=true
EXTRACTION_PRIVILEGED_TENANTS=                         # Comma-separated tenant IDs exempt from mesh
EXTRACTION_PRIVILEGED_API_KEYS=                        # Comma-separated API keys exempt from mesh
EXTRACTION_BATCH_INTERNAL_ONLY=true
EXTRACTION_ALERT_ON_ORANGE=true
EXTRACTION_ALERT_ON_RED=true

# === Stripe Billing ===
# Stripe-managed subscription billing for the AETHER P1-P4 plan catalog.
# When STRIPE_BILLING_ENABLED=true in non-local environments, the secret key,
# webhook secret, P1-P4 price IDs, and checkout/portal URLs are required.
# In AETHER_ENV=local, missing Stripe config is permitted: checkout/portal
# routes will return mocked URLs instead of failing.
# STRIPE_OVERAGE_PRICE_ID is OPTIONAL — required ONLY if charging AETHER
# overage usage through Stripe invoices. When unset, the existing AETHER
# overage calculation (shared/billing/overage.py) is used internally and no
# Stripe overage invoice can be created.
STRIPE_BILLING_ENABLED=false
STRIPE_SECRET_KEY=                              # [REQUIRED IN PRODUCTION when STRIPE_BILLING_ENABLED]
STRIPE_WEBHOOK_SECRET=                          # [REQUIRED IN PRODUCTION when STRIPE_BILLING_ENABLED]
STRIPE_PRICE_P1=                                # Recurring subscription Price ID for P1 Hobbyist
STRIPE_PRICE_P2=                                # Recurring subscription Price ID for P2 Professional
STRIPE_PRICE_P3=                                # Recurring subscription Price ID for P3 Growth Intelligence
STRIPE_PRICE_P4=                                # Recurring subscription Price ID for P4 Protocol Master
STRIPE_OVERAGE_PRICE_ID=                        # OPTIONAL — Price ID for Stripe-charged overage line items
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/billing

# === GeoIP Enrichment (MaxMind GeoLite2) ===
GEOIP_DB_PATH=/usr/share/GeoIP/GeoLite2-City.mmdb
GEOIP_ASN_DB_PATH=/usr/share/GeoIP/GeoLite2-ASN.mmdb

# === Agent Layer ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=8

# === ML Serving ===
ML_SERVING_URL=http://localhost:8080

# === Data Ingestion (Node.js) ===
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
BATCH_SIZE=500
MAX_EVENT_SIZE_KB=32

# === Social API Keys (Agent Workers) ===
TWITTER_BEARER_TOKEN=
DISCORD_BOT_TOKEN=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=

# === Market Data Providers ===
COINGECKO_API_KEY=                         # Optional — free tier works without key
BINANCE_API_KEY=                           # [REQUIRED for CEX data]
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# === Prediction Market Providers ===
POLYMARKET_API_KEY=                        # Optional — public API available
KALSHI_API_KEY=                            # [REQUIRED for Kalshi]
KALSHI_API_SECRET=

# === Web3 Social Providers ===
FARCASTER_API_KEY=                         # Neynar API key for Farcaster data
LENS_API_KEY=                              # Optional — Lens Protocol API token

# === Identity Enrichment ===
ENS_SUBGRAPH_URL=                          # Optional — custom ENS subgraph endpoint
GITHUB_PAT=                                # GitHub Personal Access Token

# === Governance ===
SNAPSHOT_GRAPHQL_URL=                      # Optional — custom Snapshot hub endpoint

# === On-Chain Intelligence (contract required) ===
CHAINALYSIS_API_KEY=                       # Chainalysis risk API (requires contract)
NANSEN_API_KEY=                            # Nansen wallet labels (requires contract)

# === TradFi Data (subscription required) ===
MASSIVE_API_KEY=                           # Massive alternative data (requires contract)
DATABENTO_API_KEY=                         # Databento market data (requires subscription)
